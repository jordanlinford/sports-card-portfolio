# =============================================================================
# Sports Card Portfolio - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set for the app to start.
# Lines marked [OPTIONAL] enable extra features but are not mandatory.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sports_card_portfolio

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# [OPTIONAL] Port the server listens on (default: 5000)
PORT=5000

# [OPTIONAL] Node environment — "production" serves static assets; anything else starts Vite dev server
NODE_ENV=development

# -----------------------------------------------------------------------------
# Session / Auth (general)
# -----------------------------------------------------------------------------

# [REQUIRED] Secret used to sign session cookies (use a long random string)
SESSION_SECRET=your_session_secret_here

# -----------------------------------------------------------------------------
# Replit Auth (OIDC)
# -----------------------------------------------------------------------------

# [OPTIONAL] Replit OIDC issuer URL (defaults to https://replit.com/oidc)
ISSUER_URL=https://replit.com/oidc

# [OPTIONAL] Replit app ID — used as the OIDC client_id and for logout redirect
REPL_ID=your_replit_app_id

# [OPTIONAL] Replit identity token (set automatically by Replit runtime)
REPL_IDENTITY=

# [OPTIONAL] Replit deployment renewal token (set automatically by Replit runtime)
WEB_REPL_RENEWAL=

# [OPTIONAL] Comma-separated list of Replit domains (set automatically by Replit runtime)
REPLIT_DOMAINS=

# [OPTIONAL] The production deployment domain (set automatically by Replit deployments)
REPLIT_DEPLOYMENT_DOMAIN=

# [OPTIONAL] Set to "1" when running inside a Replit deployment (set automatically)
REPLIT_DEPLOYMENT=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------

# [OPTIONAL] Google OAuth 2.0 credentials — enables "Sign in with Google"
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# [OPTIONAL] Override the Google OAuth callback URL (auto-derived from REPLIT_DOMAINS if unset)
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# -----------------------------------------------------------------------------
# QA / Admin
# -----------------------------------------------------------------------------

# [OPTIONAL] Token to gate QA login bypass and admin endpoints (regression, cleanup)
# Must be a long random string; share only with trusted QA automation
QA_LOGIN_TOKEN=your_qa_token_here

# -----------------------------------------------------------------------------
# AI / Gemini
# -----------------------------------------------------------------------------

# [REQUIRED for AI features] Google Gemini API key (used by card scanner, outlook engine,
# agent service, hidden gems, portfolio intelligence, growth projections, price service, etc.)
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here

# [REQUIRED for AI features] Gemini base URL provided by the Replit AI integrations connector
AI_INTEGRATIONS_GEMINI_BASE_URL=https://ai.replit.dev

# [OPTIONAL] Fallback Gemini API key used by agentService and playerRegistryAiUpdate
# when AI_INTEGRATIONS_GEMINI_API_KEY is not set
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------

# [OPTIONAL] Replit Stripe connector hostname (set automatically by Replit runtime)
REPLIT_CONNECTORS_HOSTNAME=

# [OPTIONAL] Stripe price ID for the Pro subscription checkout
STRIPE_PRICE_ID=price_your_stripe_price_id

# [OPTIONAL] Stripe Price ID for annual Pro plan (2 months free)
STRIPE_ANNUAL_PRICE_ID=price_your_annual_stripe_price_id

# [OPTIONAL] Base URL for Stripe checkout success/cancel redirects (defaults to https://<hostname>)
BASE_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# Email (Zoho SMTP)
# -----------------------------------------------------------------------------

# [OPTIONAL] Zoho SMTP host (default: smtp.zoho.com)
ZOHO_SMTP_HOST=smtp.zoho.com

# [OPTIONAL] Zoho sender email address — also used as the "from" address
ZOHO_EMAIL=info@yourdomain.com

# [OPTIONAL] Zoho app-specific password (generate at https://accounts.zoho.com/home#security/security_pwd)
ZOHO_APP_PASSWORD=your_zoho_app_password_here

# -----------------------------------------------------------------------------
# Custom Domain
# -----------------------------------------------------------------------------

# [OPTIONAL] Custom domain for canonical URLs, social share links, etc. (default: sportscardportfolio.io)
CUSTOM_DOMAIN=sportscardportfolio.io

# -----------------------------------------------------------------------------
# Object Storage (Replit)
# -----------------------------------------------------------------------------

# [OPTIONAL] Comma-separated public object search paths (set automatically by Replit)
PUBLIC_OBJECT_SEARCH_PATHS=

# [OPTIONAL] Private object directory (set automatically by Replit)
PRIVATE_OBJECT_DIR=

# -----------------------------------------------------------------------------
# Population Data Ingestion
# -----------------------------------------------------------------------------

# [OPTIONAL] API key to authenticate external population-data ingestion requests
POP_INGESTION_API_KEY=your_pop_ingestion_api_key_here

# -----------------------------------------------------------------------------
# Client-Side (Vite — must be prefixed with VITE_)
# -----------------------------------------------------------------------------

# [OPTIONAL] Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# -----------------------------------------------------------------------------

# [OPTIONAL] Sentry DSN for error tracking and alerting
SENTRY_DSN=https://your_key@your_org.ingest.sentry.io/your_project_id
